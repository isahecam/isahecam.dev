{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["shared/lib, shared/components/ui/**"],
  "printWidth": 120,
  "singleQuote": false,
  "semi": true,
  "jsxSingleQuote": false,
  "sortImports": {
    "newlinesBetween": true
  },
  "bracketSameLine": true,
  "sortTailwindcss": {
    "stylesheet": "./app/[locale]/globals.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": false
  }
}
